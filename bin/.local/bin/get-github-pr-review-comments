#!/bin/bash
if [ -n "$1" ]; then
  pr_number="$1"
else
  read -p "Enter pull request number: " pr_number
fi
gh api repos/:owner/:repo/pulls/$pr_number/comments | \
  jq '[ .[]
        | select(.line != null)
        | { path, user: {login: .user.login, type: .user.type}, diff_hunk, line, start_line, body }
      ]'
